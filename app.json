{
  "expo": {
    "name": "Pictoxam",
    "slug": "pictoxam",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "plugins": [
      [
        "expo-image-picker",
        {
          "cameraPermission": "Allow $(PRODUCT_NAME) to use the camera to take a photo for AI analysis.",
          "photosPermission": "Allow $(PRODUCT_NAME) to access photos if you pick from the library."
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Allow $(PRODUCT_NAME) to use the camera to capture multiple exam pages."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#22c55e",
          "defaultChannel": "pictoxam-answers"
        }
      ],
      "expo-secure-store"
    ],
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.picturetosms.app",
      "infoPlist": {
        "NSCameraUsageDescription": "This app needs the camera to take a picture to send to ChatGPT.",
        "NSPhotoLibraryUsageDescription": "Optional access if you choose a photo from your library."
      }
    },
    "android": {
      "package": "com.picturetosms.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.SEND_SMS",
        "android.permission.READ_PHONE_STATE",
        "android.permission.INTERNET",
        "android.permission.RECORD_AUDIO",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.POST_NOTIFICATIONS"
      ],
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "040a4b26-22db-46f3-acd6-ed0a5342863d"
      }
    },
    "owner": "vadvoood"
  }
}
