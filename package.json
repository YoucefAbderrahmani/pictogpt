{
  "name": "picturetosms",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "eas:apk": "eas build --platform android --profile preview",
    "eas:android:prod": "eas build --platform android --profile production --non-interactive",
    "server": "node server/index.js",
    "postinstall": "node -e \"if(!process.env.VERCEL){require('child_process').execSync('patch-package',{stdio:'inherit'});}\""
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "2.2.0",
    "@vercel/kv": "^3.0.0",
    "expo": "~54.0.33",
    "expo-camera": "~17.0.10",
    "expo-constants": "~18.0.13",
    "expo-document-scanner": "^0.2.5",
    "expo-image-manipulator": "~14.0.8",
    "expo-image-picker": "~17.0.11",
    "expo-notifications": "~0.32.17",
    "expo-secure-store": "~15.0.8",
    "expo-sms": "~14.0.8",
    "expo-status-bar": "~3.0.9",
    "google-auth-library": "^10.6.2",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-nitro-modules": "^0.35.6",
    "react-native-sms-android": "^0.4.1",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@types/react": "~19.1.0",
    "eas-cli": "^18.9.1",
    "patch-package": "^8.0.1",
    "typescript": "~5.9.2"
  },
  "private": true
}
