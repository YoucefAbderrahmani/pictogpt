{
  "name": "picturetosms",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "eas:apk": "eas build --platform android --profile preview",
    "server": "node server/index.js",
    "postinstall": "node -e \"if(!process.env.VERCEL){require('child_process').execSync('patch-package',{stdio:'inherit'});}\""
  },
  "dependencies": {
    "expo": "~54.0.33",
    "expo-camera": "^55.0.16",
    "expo-image-picker": "~17.0.11",
    "expo-secure-store": "~15.0.8",
    "expo-sms": "~14.0.8",
    "expo-status-bar": "~3.0.9",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-sms-android": "^0.4.1",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@types/react": "~19.1.0",
    "eas-cli": "^16.28.0",
    "patch-package": "^8.0.1",
    "typescript": "~5.9.2"
  },
  "private": true
}
