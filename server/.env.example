# Copy this file to .env and fill in your real keys. Never commit .env.

OPENROUTER_API_KEY=sk-or-v1-your-primary-openrouter-key
# Optional: extra OpenRouter keys, tried in order if the previous one fails:
# OPENROUTER_API_KEY_2=sk-or-v1-your-second-key
# OPENROUTER_API_KEY_3=sk-or-v1-your-third-key
# OPENROUTER_API_KEY_4=sk-or-v1-your-fourth-key

GEMINI_API_KEY=AIzaSy-your-primary-gemini-key
# Optional: extra Gemini keys (used after all OpenRouter keys fail), same order:
# GEMINI_API_KEY_2=
# GEMINI_API_KEY_3=
# GEMINI_API_KEY_4=

CLIENT_BEARER_TOKEN=your-random-secret
PORT=8787

# Optional: max completion tokens (defaults 1024; server auto-halves on credit/quota errors before next model)
# OPENROUTER_MAX_TOKENS=2048
# GEMINI_MAX_OUTPUT_TOKENS=2048
