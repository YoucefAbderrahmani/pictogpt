# Copy this file to .env and fill in your real keys. Never commit .env.

# Required — image analysis uses OpenRouter only (no direct Google Gemini or DeepSeek).
OPENROUTER_API_KEY=sk-or-v1-your-primary-openrouter-key
# Optional: extra OpenRouter keys, tried in order if the previous one fails:
# OPENROUTER_API_KEY_2=sk-or-v1-your-second-key
# OPENROUTER_API_KEY_3=sk-or-v1-your-third-key
# OPENROUTER_API_KEY_4=sk-or-v1-your-fourth-key

# Optional: OpenRouter model chain (defaults try `google/gemini-*` first, then other vision models).
# OPENROUTER_MODEL=google/gemini-2.5-flash
# OPENROUTER_MODELS=google/gemini-2.5-flash,google/gemini-2.5-pro,openai/gpt-4o-mini

# Optional: OpenRouter attribution (recommended on serverless).
# OPENROUTER_HTTP_REFERER=https://your-app.example
# OPENROUTER_APP_TITLE=PictureToSMS

CLIENT_BEARER_TOKEN=your-random-secret
PORT=8787

# Admin panel (POST /v1/admin): same password you enter in the app.
ADMIN_PANEL_PASSWORD=choose-a-strong-admin-secret

# Shared suspend toggle + team-wide answer log (Redis REST).
# Vercel’s Upstash integration usually sets these (the API also accepts legacy KV_* names):
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
# Legacy Vercel KV names (same values as in Upstash “REST API” if you copy manually):
# KV_REST_API_URL=
# KV_REST_API_TOKEN=
# Without Redis, suspend-from-app and shared logs are unavailable; you can still use:
# SUSPEND_ALL_REQUESTS=true  (redeploy to change; blocks all /v1/analyze calls)

# Optional: max completion tokens for OpenRouter (default 1024; server halves on budget errors before next model)
# OPENROUTER_MAX_TOKENS=2048

# Optional OCR preprocessing (grayscale/normalize/sharpen) before AI analysis — skipped when Document AI returns a page image:
# OCR_IMAGE_ENHANCE=true

# Optional: Google Cloud Document AI (Enterprise Document OCR) — server-side deskew for burst photos.
# Create an "Enterprise Document OCR" processor in GCP Console → Document AI. Grant the service account role
# "Document AI API User" (roles/documentai.apiUser) or permission documentai.processors.processOnline.
#
# Either paste minified JSON (one line), OR base64-encode the whole JSON file for Vercel:
#   PowerShell: [Convert]::ToBase64String([IO.File]::ReadAllBytes("service-account.json"))
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...",...}
# GOOGLE_SERVICE_ACCOUNT_JSON_BASE64=   (alternative to GOOGLE_SERVICE_ACCOUNT_JSON)
#
# DOCUMENT_AI_PROJECT_ID=your-gcp-project-id
# (optional) same value as: GOOGLE_CLOUD_PROJECT or GCP_PROJECT
# DOCUMENT_AI_LOCATION=us
# DOCUMENT_AI_PROCESSOR_ID=hex-processor-id-from-console
# If the API returns 404 or "processor version", set the deployed version id (Console → processor → versions):
# DOCUMENT_AI_PROCESSOR_VERSION=your-version-id
# Rare: override API host (default https://LOCATION-documentai.googleapis.com/v1)
# DOCUMENT_AI_API_ROOT=https://us-documentai.googleapis.com/v1
# DOCUMENT_AI_ENABLED=true
# Set DOCUMENT_AI_ENABLED=false to turn off without removing other vars.
